# ---- Copy to .env and fill in secrets. All env access goes through src/config.ts. ----

# Runtime
NODE_ENV=development

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/support_console
# Separate DB for the integration/concurrency tests (created by docker/init)
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/support_console_test

# Auth: signing secret for the session JWT (min 16 chars). CHANGE THIS in real deployments.
AUTH_SECRET=change-me-to-a-long-random-string
SESSION_TTL_HOURS=24

# LLM (Google Gemini free tier). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Policy thresholds (guardrail/policy tuning; safety does NOT depend on these being "right")
AUTO_REFUND_MAX=50.00
CANCEL_AUTO_WINDOW_HOURS=24
REPLACEMENT_WINDOW_DAYS=30
